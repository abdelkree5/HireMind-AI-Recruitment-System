# ===== Backend Configuration =====

# Server settings
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_RELOAD=true

# Database
DATABASE_URL=sqlite:///./database/hiremind.db
# For PostgreSQL: postgresql://user:password@localhost:5432/hiremind_db

# API Keys and Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI/ML Settings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
# Change to 'cuda' if GPU is available: EMBEDDING_DEVICE=cuda

# Interview API (if using external service)
INTERVIEW_API_KEY=your-interview-api-key
INTERVIEW_API_URL=http://localhost:8000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/hiremind.log

# ===== Frontend Configuration =====

# API Endpoint
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_API_TIMEOUT=30000

# Application Settings
VITE_APP_NAME=HireMind AI Platform
VITE_APP_VERSION=1.0.0

# ===== Database Configuration =====

# SQLite (default)
DB_TYPE=sqlite
DB_PATH=./database/hiremind.db

# PostgreSQL (optional)
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=hiremind_user
# DB_PASSWORD=secure_password
# DB_NAME=hiremind_db

# ===== AI Training Configuration =====

# Model Training
TRAINING_DATA_PATH=./ai_engine/training/data
CHECKPOINT_DIR=./checkpoints
BATCH_SIZE=32
EPOCHS=3
LEARNING_RATE=2e-5

# ===== Feature Flags =====

# Enable/disable features
ENABLE_CV_ANALYSIS=true
ENABLE_AI_MATCHING=true
ENABLE_SKILL_EXTRACTION=true
ENABLE_AI_INTERVIEW=true
ENABLE_REAL_TIME_UPDATES=true

# ===== Development Settings =====

# Debug mode (set to false in production)
DEBUG=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# File Upload Settings
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,docx,doc,txt

# ===== Email Configuration (if applicable) =====

# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=noreply@hiremind.app
